                                    </TableColumn>
                                    <TableColumn text="Start Date" prefWidth="80">
                                        <cellValueFactory>
                                            <PropertyValueFactory property="startDateLabel"/>
                                        </cellValueFactory>
                                    </TableColumn>
                                    <TableColumn text="End Date" prefWidth="80">
