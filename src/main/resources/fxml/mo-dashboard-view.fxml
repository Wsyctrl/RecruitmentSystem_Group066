                                        <PropertyValueFactory property="email"/>
                                    </cellValueFactory>
                                </TableColumn>
                                <TableColumn text="Ongoing Jobs" prefWidth="95">
                                    <cellValueFactory>
                                        <PropertyValueFactory property="currentOngoingJobsCount"/>
                                    </cellValueFactory>
                                </TableColumn>
                                <TableColumn text="Applied" prefWidth="60">
                                    <cellValueFactory>
                                        <PropertyValueFactory property="appliedCount"/>
                                    </cellValueFactory>
                                </TableColumn>
                                <TableColumn text="Hired" prefWidth="55">
                                    <cellValueFactory>
                                        <PropertyValueFactory property="hiredCount"/>
                                    </cellValueFactory>
                                </TableColumn>
                                <TableColumn text="Status" prefWidth="70">
                                    <cellValueFactory>
                                        <PropertyValueFactory property="statusLabel"/>
                                    </cellValueFactory>
                                </TableColumn>
                            </columns>
                        </TableView>
                        <HBox spacing="8">
                            <Button text="Reset password" onAction="#handleResetTaPassword" styleClass="btn-outline"/>
                            <Button text="Enable / disable" onAction="#handleToggleTaStatus" styleClass="btn-danger"/>
                        </HBox>
                    </VBox>
                    <VBox spacing="12" styleClass="detail-panel">
                        <padding>
                            <Insets top="16" right="16" bottom="16" left="16"/>
                        </padding>
                        <Label text="TA Details" styleClass="h5"/>
                        <VBox spacing="2">
                            <Label fx:id="adminTaNameLabel" styleClass="h6"/>
                            <Label fx:id="adminTaInfoLabel"/>
                        </VBox>
                        <VBox spacing="4" VBox.vgrow="ALWAYS">
                            <Label text="Jobs Applied" styleClass="text-muted"/>
                            <TableView fx:id="adminTaAppliedJobsTable" prefHeight="150">
                                <columns>
                                    <TableColumn text="Job ID" prefWidth="85">
                                        <cellValueFactory>
                                            <PropertyValueFactory property="jobId"/>
                                        </cellValueFactory>
                                    </TableColumn>
                                    <TableColumn text="Job Name" prefWidth="180">
                                        <cellValueFactory>
                                            <PropertyValueFactory property="jobName"/>
                                        </cellValueFactory>
                                    </TableColumn>
                                </columns>
                            </TableView>
                        </VBox>
                        <VBox spacing="4">
                            <Label text="Jobs Hired" styleClass="text-muted"/>
                            <TableView fx:id="adminTaHiredJobsTable" prefHeight="150">
                                <columns>
                                    <TableColumn text="Job ID" prefWidth="85">
                                        <cellValueFactory>
                                            <PropertyValueFactory property="jobId"/>
                                        </cellValueFactory>
                                    </TableColumn>
                                    <TableColumn text="Job Name" prefWidth="130">
                                        <cellValueFactory>
                                            <PropertyValueFactory property="jobName"/>
                                        </cellValueFactory>
                                    </TableColumn>
                                    <TableColumn text="Hired Time" prefWidth="100">
                                        <cellValueFactory>
                                            <PropertyValueFactory property="time"/>
                                        </cellValueFactory>
                                    </TableColumn>
                                    <TableColumn text="Work Period" prefWidth="120">
                                        <cellValueFactory>
                                            <PropertyValueFactory property="workPeriod"/>
                                        </cellValueFactory>
                                    </TableColumn>
                                </columns>
                            </TableView>
                        </VBox>
                    </VBox>
                </SplitPane>
            </Tab>
            <Tab text="MO admin" fx:id="adminMoTab">
                <SplitPane dividerPositions="0.5">
                    <VBox spacing="8" styleClass="p-3">
                        <Label text="MO accounts" styleClass="h5"/>
                        <TableView fx:id="adminMoTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn text="Name" prefWidth="110">
                                    <cellValueFactory>
                                        <PropertyValueFactory property="fullName"/>
                                    </cellValueFactory>
                                </TableColumn>
                                <TableColumn text="Phone" prefWidth="110">
                                    <cellValueFactory>
                                        <PropertyValueFactory property="phone"/>
                                    </cellValueFactory>
                                </TableColumn>
                                <TableColumn text="Email" prefWidth="180">
                                    <cellValueFactory>
                                        <PropertyValueFactory property="email"/>
                                    </cellValueFactory>
                                </TableColumn>
                                <TableColumn text="Classes" prefWidth="60">
                                    <cellValueFactory>
