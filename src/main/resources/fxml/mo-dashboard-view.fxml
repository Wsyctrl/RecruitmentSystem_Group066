                                </TableColumn>
                                <TableColumn text="Status" prefWidth="60">
                                    <cellValueFactory>
                                        <PropertyValueFactory property="statusLabel"/>
                                    </cellValueFactory>
                                </TableColumn>
                            </columns>
                        </TableView>
                    </center>
                    <bottom>
                        <HBox spacing="8" alignment="CENTER_RIGHT" styleClass="p-3">
                            <Button text="Generate 30-Day Hiring Insights" onAction="#handleAiGenerateInsights"/>
                            <Button text="Close Job" onAction="#handleAdminToggleJob" styleClass="btn-danger"/>
