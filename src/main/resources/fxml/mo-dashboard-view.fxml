                                    <cellValueFactory>
                                        <PropertyValueFactory property="jobId"/>
                                    </cellValueFactory>
                                </TableColumn>
                                <TableColumn text="Title" prefWidth="170">
                                    <cellValueFactory>
                                        <PropertyValueFactory property="jobName"/>
                                    </cellValueFactory>
                                </TableColumn>
                                <TableColumn text="Module" prefWidth="120">
                                    <cellValueFactory>
                                        <PropertyValueFactory property="moduleName"/>
                                    </cellValueFactory>
                                </TableColumn>
                                <TableColumn text="Name" prefWidth="100">
                                    <cellValueFactory>
                                        <PropertyValueFactory property="moName"/>
                                    </cellValueFactory>
                                </TableColumn>
                                <TableColumn text="Email" prefWidth="140">
                                    <cellValueFactory>
                                        <PropertyValueFactory property="moId"/>
                                    </cellValueFactory>
                                </TableColumn>
                                <TableColumn text="Positions" prefWidth="60">
                                    <cellValueFactory>
                                        <PropertyValueFactory property="numberOfPositions"/>
                                    </cellValueFactory>
                                </TableColumn>
                                <TableColumn text="Hired" prefWidth="50">
                                    <cellValueFactory>
                                        <PropertyValueFactory property="hiredCount"/>
