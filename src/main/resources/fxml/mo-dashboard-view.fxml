                            <Label fx:id="adminMoNameLabel" styleClass="h6"/>
                            <Label fx:id="adminMoInfoLabel"/>
                        </VBox>
                        <VBox spacing="4" VBox.vgrow="ALWAYS">
                            <Label text="Classes/Jobs" styleClass="text-muted"/>
                            <TableView fx:id="adminMoJobsTable" prefHeight="280">
                                <columns>
                                    <TableColumn text="Job ID" prefWidth="85">
                                        <cellValueFactory>
                                            <PropertyValueFactory property="jobId"/>
