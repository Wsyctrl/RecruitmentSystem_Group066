<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.bupt.tarecruit.controller.RegisterController"
            styleClass="root">
    <center>
        <StackPane>
            <padding>
                <Insets top="50" right="80" bottom="50" left="80"/>
            </padding>
            <VBox alignment="CENTER" spacing="14" maxWidth="400" styleClass="card">
                <padding>
                    <Insets top="32" right="32" bottom="32" left="32"/>
                </padding>
                <Label text="Create Account" styleClass="h2">
                    <VBox.margin>
                        <Insets bottom="4"/>
                    </VBox.margin>
                </Label>
                <Label text="Register as TA or MO" styleClass="text-muted">
                    <VBox.margin>
                        <Insets bottom="20"/>
                    </VBox.margin>
                </Label>
                <VBox spacing="6" maxWidth="Infinity">
                    <Label text="I am a" styleClass="form-label"/>
                    <ChoiceBox fx:id="roleChoice" maxWidth="Infinity"/>
                </VBox>
                <VBox spacing="6" maxWidth="Infinity">
                    <Label text="BUPT Email" styleClass="form-label"/>
                    <TextField fx:id="userIdField" promptText="Must end with @bupt.edu.cn"/>
                </VBox>
                <VBox spacing="6" maxWidth="Infinity">
                    <Label text="Password" styleClass="form-label"/>
                    <PasswordField fx:id="passwordField" promptText="Choose a password"/>
                </VBox>
                <VBox spacing="6" maxWidth="Infinity">
                    <Label text="Confirm Password" styleClass="form-label"/>
                    <PasswordField fx:id="confirmPasswordField" promptText="Confirm your password"/>
                </VBox>
                <Button text="Register" onAction="#handleRegister" maxWidth="Infinity" styleClass="btn-primary btn-lg">
                    <VBox.margin>
                        <Insets top="12"/>
                    </VBox.margin>
                </Button>
                <Button text="Back to sign in" onAction="#handleBackToLogin" maxWidth="Infinity" styleClass="btn-outline"/>
            </VBox>
        </StackPane>
    </center>
</BorderPane>
