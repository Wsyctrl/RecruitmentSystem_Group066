<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.bupt.tarecruit.controller.LoginController"
            styleClass="root">
    <top>
        <HBox alignment="CENTER" minHeight="56" prefHeight="56" maxHeight="56">
            <HBox fx:id="noticeBox" visible="false" managed="false" alignment="CENTER_LEFT"
                  maxWidth="360"
                  style="-fx-background-color: #fff3cd; -fx-border-color: #ffe69c; -fx-border-width: 1; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 10 14;">
                <Label fx:id="noticeLabel" textFill="#664d03" wrapText="true"/>
            </HBox>
        </HBox>
    </top>
    <center>
        <StackPane>
            <padding>
                <Insets top="60" right="80" bottom="60" left="80"/>
            </padding>
            <VBox alignment="CENTER" spacing="16" maxWidth="380" styleClass="card">
                <padding>
                    <Insets top="36" right="36" bottom="36" left="36"/>
                </padding>
                <HBox alignment="CENTER_LEFT" maxWidth="Infinity">
                    <Button fx:id="backButton" text="←" onAction="#handleBackToBrowse"
                            style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-text-fill: #98a2b3;"/>
                </HBox>
                <Label text="TA Recruitment" styleClass="h2">
                    <VBox.margin>
                        <Insets bottom="4"/>
                    </VBox.margin>
                </Label>
                <Label text="Sign in to continue" styleClass="text-muted">
                    <VBox.margin>
                        <Insets bottom="24"/>
                    </VBox.margin>
                </Label>
                <VBox spacing="6" maxWidth="Infinity">
                    <Label text="BUPT Email" styleClass="form-label"/>
                    <TextField fx:id="userIdField" promptText="Enter your @bupt.edu.cn email"/>
                </VBox>
                <VBox spacing="6" maxWidth="Infinity">
                    <Label text="Password" styleClass="form-label"/>
                    <PasswordField fx:id="passwordField" promptText="Enter your password"/>
                </VBox>
                <Button text="Sign in" onAction="#handleLogin" maxWidth="Infinity" styleClass="btn-primary btn-lg">
                    <VBox.margin>
                        <Insets top="12"/>
                    </VBox.margin>
                </Button>
                <Hyperlink fx:id="registerLink" text="No account? Register"/>
            </VBox>
        </StackPane>
    </center>
</BorderPane>
